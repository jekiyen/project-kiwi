# ─── AI Provider ─────────────────────────────────────────────────────────────
# Options: claude | manual
AI_PROVIDER=manual
ANTHROPIC_API_KEY=
# Claude-specific (only used when AI_PROVIDER=claude)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_TIMEOUT_SECONDS=30
CLAUDE_MAX_RETRIES=2

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Notifications stay silently disabled until all three are set (Phase 6.2B).
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Notifications ────────────────────────────────────────────────────────────
# Minimum AI match score (0-100) that triggers a "high match job" notification.
NOTIFY_HIGH_SCORE_THRESHOLD=80

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./kiwi.db

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCAN_INTERVAL_HOURS=6

# ─── Server ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
